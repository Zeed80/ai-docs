{
  "name": "sveta-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Android shell (Capacitor) for the AI Manufacturing Workspace — loads the live frontend and adds native capabilities.",
  "scripts": {
    "sync": "cap sync android",
    "open": "cap open android",
    "add:android": "cap add android",
    "build:debug": "cd android && ./gradlew assembleDebug",
    "build:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor-mlkit/document-scanner": "^8.1.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capgo/capacitor-native-biometric": "^8.4.11",
    "send-intent": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
