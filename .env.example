# Mailbox 2: Accounting
IMAP_ACCOUNTING_HOST=
IMAP_ACCOUNTING_PORT=993
IMAP_ACCOUNTING_USER=
IMAP_ACCOUNTING_PASSWORD=
IMAP_ACCOUNTING_SSL=true

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
