# === Database ===
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aiworkspace
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=aiworkspace

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === MinIO ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_in_production
MINIO_BUCKET=documents

# === Qdrant ===
QDRANT_URL=http://qdrant:6333

# === Ollama ===
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL_OCR=gemma4:e4b
OLLAMA_MODEL_REASONING=gemma4:26b

# === Headless CAD kernel (FreeCAD/OpenCascade, internal in Docker) ===
CAD_KERNEL_URL=http://cad-kernel:8092

# === Claude API (optional, for reasoning) ===
ANTHROPIC_API_KEY=
AI_REASONING_BACKEND=ollama  # ollama | claude

# === Email (IMAP/SMTP) ===
# Mailbox 1: Procurement
IMAP_PROCUREMENT_HOST=
IMAP_PROCUREMENT_PORT=993
IMAP_PROCUREMENT_USER=
IMAP_PROCUREMENT_PASSWORD=
IMAP_PROCUREMENT_SSL=true

# Mailbox 2: Accounting
IMAP_ACCOUNTING_HOST=
IMAP_ACCOUNTING_PORT=993
IMAP_ACCOUNTING_USER=
IMAP_ACCOUNTING_PASSWORD=
IMAP_ACCOUNTING_SSL=true

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@company.com

# === Application ===
APP_SECRET_KEY=changeme_in_production
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# === Auth (Authentik SSO) ===
# Set AUTH_ENABLED=true in production to enforce JWT verification.
# In development (AUTH_ENABLED=false) all requests are treated as admin.
AUTH_ENABLED=false
AUTHENTIK_URL=http://authentik-server:9000
AUTHENTIK_SLUG=ai-workspace
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Authentik internal DB (separate from the main app DB)
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASSWORD=changeme_in_production
AUTHENTIK_DB_NAME=authentik
# Must be a long random string — run: python3 -c "import secrets; print(secrets.token_hex(50))"
AUTHENTIK_SECRET_KEY=changeme_in_production
# Bootstrap admin account (used only on first Authentik start)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@company.com
AUTHENTIK_BOOTSTRAP_PASSWORD=changeme_in_production

# === Frontend ===
NEXT_PUBLIC_API_URL=same-origin
NEXT_PUBLIC_WS_URL=same-origin

# === Traefik ===
TRAEFIK_DOMAIN=localhost
TRAEFIK_ACME_EMAIL=admin@company.com
