{
  "title": "AI Workspace — Overview",
  "uid": "aiworkspace-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Agent Turns (total)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(aiworkspace_agent_turns_total)",
          "legendFormat": "Turns"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Invoices Approved",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(aiworkspace_invoices_approved_total)",
          "legendFormat": "Approved"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Anomalies Detected",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(aiworkspace_anomalies_detected_total)",
          "legendFormat": "Anomalies"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Agent Turn Duration (p50/p95)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(aiworkspace_agent_turn_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(aiworkspace_agent_turn_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Extraction Duration (p50/p95)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(aiworkspace_extraction_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(aiworkspace_extraction_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tool Calls per Minute",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (tool) (rate(aiworkspace_agent_tool_calls_total[1m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Approval Wait Time (p50/p90)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(aiworkspace_approval_wait_seconds_bucket[1h]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.9, rate(aiworkspace_approval_wait_seconds_bucket[1h]))",
          "legendFormat": "p90"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (path) (rate(aiworkspace_http_requests_total[1m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Request Duration p95 (ms)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(aiworkspace_http_request_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "{{path}} p95"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Celery Queue Depth",
      "gridPos": { "x": 0, "y": 28, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(aiworkspace_celery_queue_depth)",
          "legendFormat": "Pending tasks"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Ollama VRAM Used (GB)",
      "gridPos": { "x": 4, "y": 28, "w": 10, "h": 4 },
      "targets": [
        {
          "expr": "aiworkspace_ollama_vram_used_bytes / 1e9",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Agent Steps (total)",
      "gridPos": { "x": 14, "y": 28, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(aiworkspace_agent_steps_total)",
          "legendFormat": "Steps"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Active WebSocket Connections",
      "gridPos": { "x": 18, "y": 28, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "aiworkspace_ws_connections_active",
          "legendFormat": "WS connections"
        }
      ]
    }
  ]
}
