# Copy to infra/.env (make setup). NEVER commit infra/.env — it is gitignored.
# Generate strong secrets with: bash infra/scripts/gen-secrets.sh
#
# Defaults below are for LOCAL DEVELOPMENT. For production see the marked block at the
# bottom — backend refuses to start in APP_ENV=production with these dev defaults.

# === Application ===
APP_ENV=development
APP_DEBUG=false
APP_SECRET_KEY=dev-secret-key
APP_LOG_LEVEL=INFO
CSRF_SECRET=dev-csrf-secret
CSP_ENABLED=false

# === PostgreSQL ===
POSTGRES_USER=aiworkspace
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aiworkspace

# === MinIO ===
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=documents

# === Frontend / CORS ===
# In dev, the frontend talks to the backend directly. In prod use same-origin (via Traefik).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
CORS_ORIGINS=http://localhost:3000

# === Traefik ===
TRAEFIK_DOMAIN=localhost
TRAEFIK_ACME_EMAIL=admin@company.com

# === AI ===
AI_REASONING_BACKEND=ollama
# ANTHROPIC_API_KEY=sk-ant-...

# === Internal service-to-service key (AI orchestrator → backend) ===
AGENT_SERVICE_KEY=agent-internal-key-2026

# === Auth (Authentik SSO) ===
# Set AUTH_ENABLED=true in production to enable SSO.
AUTH_ENABLED=false
# Internal URL the backend uses for JWKS/token (Docker service name, NOT the host port).
AUTHENTIK_URL=http://authentik-server:9000
# External URL the browser is redirected to for login. Dev: http://localhost:9100.
AUTHENTIK_EXTERNAL_URL=http://localhost:9100
AUTHENTIK_SLUG=ai-workspace
OAUTH_CLIENT_ID=ai-workspace
OAUTH_CLIENT_SECRET=

# === Authentik DB / bootstrap ===
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASSWORD=authentik
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_SECRET_KEY=please-change-me-in-production
AUTHENTIK_BOOTSTRAP_EMAIL=admin@company.com
AUTHENTIK_BOOTSTRAP_PASSWORD=changeme_in_production

# === SMTP (optional) ===
# SMTP_HOST=smtp.company.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@company.com

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — override the above. Run `bash infra/scripts/gen-secrets.sh` and paste.
# ─────────────────────────────────────────────────────────────────────────────
# APP_ENV=production
# AUTH_ENABLED=true
# CSP_ENABLED=true
# TRAEFIK_DOMAIN=yourdomain.com
# TRAEFIK_ACME_EMAIL=admin@yourdomain.com
# CORS_ORIGINS=https://yourdomain.com
# AUTHENTIK_EXTERNAL_URL=https://yourdomain.com
# NEXT_PUBLIC_API_URL=same-origin
# NEXT_PUBLIC_WS_URL=same-origin
# APP_SECRET_KEY=<gen>            CSRF_SECRET=<gen>            AGENT_SERVICE_KEY=<gen>
# POSTGRES_PASSWORD=<gen>         MINIO_SECRET_KEY=<gen>       OAUTH_CLIENT_SECRET=<gen>
# AUTHENTIK_SECRET_KEY=<gen>      AUTHENTIK_DB_PASSWORD=<gen>  AUTHENTIK_BOOTSTRAP_PASSWORD=<gen>
