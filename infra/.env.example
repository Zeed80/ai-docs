# === Application ===
APP_ENV=development
APP_DEBUG=false
APP_SECRET_KEY=change-me-in-production
APP_LOG_LEVEL=INFO

# === PostgreSQL ===
POSTGRES_USER=aiworkspace
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aiworkspace

# === MinIO ===
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=documents

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# === Traefik ===
TRAEFIK_DOMAIN=localhost
TRAEFIK_ACME_EMAIL=admin@company.com

# === AI ===
AI_REASONING_BACKEND=ollama
# ANTHROPIC_API_KEY=sk-ant-...

# === Auth (Authentik SSO) ===
# Set AUTH_ENABLED=true in production to enable SSO
AUTH_ENABLED=false
AUTHENTIK_URL=http://localhost:9100
AUTHENTIK_SLUG=ai-workspace
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# === Authentik DB ===
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASSWORD=change-me-in-production
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_SECRET_KEY=change-me-in-production

# === SMTP (optional) ===
# SMTP_HOST=smtp.company.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@company.com
