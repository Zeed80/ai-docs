{
  "key": "generate_qwen_image",
  "title": "Генерация по описанию (Qwen, быстрый AIO)",
  "description": "Создать изображение с нуля по тексту: «эскиз кондуктора для сверления фланца», «схема установки детали на станке», «технический линейный чертёж». Использует быстрый all-in-one чекпойнт Qwen (модель/CLIP/VAE в одном файле). Модель подбирается автоматически под установленную на сервере.",
  "category": "generate",
  "operation": "generate",
  "inject_map": {
    "prompt": {"node": "6", "input": "text"},
    "negative": {"node": "7", "input": "text"},
    "seed": {"node": "3", "input": "seed"},
    "width": {"node": "5", "input": "width"},
    "height": {"node": "5", "input": "height"}
  },
  "params_schema": {
    "seed": {"type": "int", "default": 0, "label": "Seed (0 = случайный)"},
    "steps": {"type": "int", "default": 8, "min": 1, "max": 40, "label": "Шаги"},
    "cfg": {"type": "float", "default": 1.5, "min": 1.0, "max": 8.0, "label": "CFG"},
    "width": {"type": "int", "default": 1024, "label": "Ширина"},
    "height": {"type": "int", "default": 1024, "label": "Высота"}
  },
  "graph": {
    "4": {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "Qwen-Rapid-AIO-SFW-v23.safetensors"}},
    "6": {"class_type": "CLIPTextEncode", "inputs": {"text": "", "clip": ["4", 1]}},
    "7": {"class_type": "CLIPTextEncode", "inputs": {"text": "", "clip": ["4", 1]}},
    "5": {"class_type": "EmptySD3LatentImage", "inputs": {"width": 1024, "height": 1024, "batch_size": 1}},
    "3": {"class_type": "KSampler", "inputs": {"seed": 0, "steps": 8, "cfg": 1.5, "sampler_name": "euler", "scheduler": "simple", "denoise": 1.0, "model": ["4", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0]}},
    "8": {"class_type": "VAEDecode", "inputs": {"samples": ["3", 0], "vae": ["4", 2]}},
    "60": {"class_type": "SaveImage", "inputs": {"filename_prefix": "studio_generate", "images": ["8", 0]}}
  }
}
