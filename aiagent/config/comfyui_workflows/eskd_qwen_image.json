{
  "key": "eskd_qwen_image",
  "title": "ЕСКД: диффузионный чертёж по описанию (Qwen)",
  "description": "Диффузионная альтернатива точному векторному рендеру: строит чертёж по текстовому описанию в стиле ЕСКД (чёрно-белая линейная графика, без рамки/штампа — стиль добавляется системой). Метрически НЕ точен (в отличие от «Точного векторного»), но быстрее и свободнее по компоновке. Быстрый all-in-one чекпойнт Qwen; модель подбирается под установленную на сервере.",
  "category": "eskd",
  "operation": "eskd",
  "inject_map": {
    "prompt": {"node": "6", "input": "text"},
    "seed": {"node": "3", "input": "seed"},
    "width": {"node": "5", "input": "width"},
    "height": {"node": "5", "input": "height"},
    "steps": {"node": "3", "input": "steps"},
    "cfg": {"node": "3", "input": "cfg"}
  },
  "params_schema": {
    "seed": {"type": "int", "default": 0, "label": "Seed (0 = случайный)"},
    "steps": {"type": "int", "default": 8, "min": 1, "max": 40, "label": "Шаги"},
    "cfg": {"type": "float", "default": 1.0, "min": 1.0, "max": 8.0, "label": "CFG"},
    "width": {"type": "int", "default": 1024, "label": "Ширина"},
    "height": {"type": "int", "default": 1024, "label": "Высота"}
  },
  "graph": {
    "4": {"class_type": "CheckpointLoaderSimple", "inputs": {"ckpt_name": "Qwen-Rapid-AIO-SFW-v23.safetensors"}},
    "10": {"class_type": "ModelSamplingAuraFlow", "inputs": {"model": ["4", 0], "shift": 3.0}},
    "6": {"class_type": "CLIPTextEncode", "inputs": {"text": "", "clip": ["4", 1]}},
    "7": {"class_type": "ConditioningZeroOut", "inputs": {"conditioning": ["6", 0]}},
    "5": {"class_type": "EmptySD3LatentImage", "inputs": {"width": 1024, "height": 1024, "batch_size": 1}},
    "3": {"class_type": "KSampler", "inputs": {"seed": 0, "steps": 8, "cfg": 1.0, "sampler_name": "euler", "scheduler": "simple", "denoise": 1.0, "model": ["10", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0]}},
    "8": {"class_type": "VAEDecode", "inputs": {"samples": ["3", 0], "vae": ["4", 2]}},
    "60": {"class_type": "SaveImage", "inputs": {"filename_prefix": "studio_eskd", "images": ["8", 0]}}
  }
}
